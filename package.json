{
  "name": "pulse-radio-figma-plugin",
  "version": "1.0.0",
  "type": "module",
  "description": "Live radio music player for Figma - stream free radio by genre while you design",
  "scripts": {
    "dev": "concurrently \"vite build --watch --mode development\" \"esbuild src/code.ts --bundle --format=iife --target=es2020 --outfile=dist/code.js --watch\"",
    "build": "vite build && esbuild src/code.ts --bundle --format=iife --target=es2020 --outfile=dist/code.js --minify",
    "build:ui": "vite build",
    "build:code": "esbuild src/code.ts --bundle --format=iife --target=es2020 --outfile=dist/code.js --minify"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.123.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.0.3"
  }
}
